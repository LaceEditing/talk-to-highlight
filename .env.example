# Copy this file to .env.local and fill in your credentials.
# .env.local is gitignored and never committed.

# Your Google OAuth 2.0 Client ID (Web application type)
# Get it from: https://console.cloud.google.com/ → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=

# Your Google API Key (used for the Drive Picker "Browse my Drive" button)
# Also from the same Credentials page → Create Credentials → API Key
# Not strictly required — the URL-paste tab works without it
VITE_GOOGLE_API_KEY=
