{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/vosk-models/:path*",
      "destination": "https://alphacephei.com/vosk/models/:path*"
    }
  ]
}
